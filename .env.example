# Environment Variables Template
# Copy this file to .env.local and fill in your values

# External URLs
VITE_CHROME_STORE_URL=https://chromewebstore.google.com/detail/promptready/inghgabddmlnmlgnjedkcleelonkggkg
VITE_FEEDBACK_URL=https://forms.gle/your-form-id

# Site Configuration
VITE_SITE_URL=https://promptready.app

# Analytics Configuration
VITE_ANALYTICS_ENABLED=true
VITE_PUBLIC_POSTHOG_KEY= # e.g. phc_...
VITE_PUBLIC_POSTHOG_HOST= # e.g. https://app.posthog.com

# Development Settings
# These are automatically set by Vite, but can be overridden
# NODE_ENV=development
# DEV=true
# PROD=false
